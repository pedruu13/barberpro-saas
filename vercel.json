{
  "version": 2,
  "functions": {
    "api/index.js": {
      "runtime": "vercel-node@latest",
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "routes": [
    { "src": "/api/health", "dest": "/api/index.js" },
    { "src": "/api/cron/(.*)", "dest": "/api/index.js" },
    { "src": "/api/auth/(.*)", "dest": "/api/index.js" },
    { "src": "/api/public/(.*)", "dest": "/api/index.js" },
    { "src": "/api/admin/(.*)", "dest": "/api/index.js" },
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ]
}
