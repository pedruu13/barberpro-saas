{
  "functions": {
    "backend/src/app.js": {
      "runtime": "@vercel/node@latest"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backend/src/app.js" },
    { "source": "/", "destination": "/frontend/index.html" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}
