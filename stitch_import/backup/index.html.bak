<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#121414">
  <title>BarberPro Ã¢â‚¬â€ Precisão Digital. Mestria Artesanal.</title>
  
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=Noto+Serif:ital,wght@0,400..700;1,400..700&family=Manrope:wght@200..800&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
  
  <script id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          "colors": {
            "outline": "#99907c",
            "primary": "#f2ca50",
            "background": "#121414",
            "surface": "#121414",
            "on-surface": "#e2e2e2",
            "primary-container": "#d4af37",
            "on-primary-container": "#3c2f00",
            "surface-container-lowest": "#0c0f0f",
            "surface-container-low": "#1a1c1c",
            "surface-container": "#1e2020",
            "surface-container-high": "#282a2b",
            "surface-container-highest": "#333535",
          },
          "fontFamily": {
            "serif": ["Noto Serif", "serif"],
            "sans": ["Manrope", "sans-serif"],
            "display": ["Inter", "sans-serif"]
          }
        }
      }
    }
  </script>

  <style>
    .glass-panel {
      background: rgba(255, 255, 255, 0.03);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.08);
    }
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
    .screen { display: none; }
    .screen.active { display: block; }
    body { background-color: #121414; color: #e2e2e2; font-family: 'Manrope', sans-serif; }
    
    /* Global Transition */
    * { transition: background-color 0.3s ease, border-color 0.3s ease; }
  </style>

  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('sw.js');
      });
    }
  </script>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="app.js"></script>
</head>

<body>

  <!-- Global Navigation (Elite Noir) -->
  <header class="fixed top-0 w-full z-50 bg-black/40 backdrop-blur-md border-b border-white/5 shadow-[0_0_15px_rgba(212,175,55,0.03)]">
    <div class="flex justify-between items-center px-8 h-16 w-full">
      <div class="text-xl font-bold text-white tracking-tighter italic font-serif cursor-pointer" onclick="goTo('landing')">BarberPro</div>
      <nav class="hidden md:flex gap-8 font-sans tracking-tight uppercase text-xs">
        <a class="text-zinc-400 hover:text-primary transition-colors duration-300" href="#" onclick="goTo('booking')">Serviços</a>
        <a class="text-zinc-400 hover:text-primary transition-colors duration-300" href="#">Galeria</a>
        <a class="text-zinc-400 hover:text-primary transition-colors duration-300" href="#">VIP Member</a>
      </nav>
      <div class="flex items-center gap-4">
        <button class="font-sans tracking-tight uppercase text-xs text-zinc-400 hover:text-white transition-colors" onclick="goTo('client-login')">MEU PERFIL</button>
        <button class="font-sans tracking-tight uppercase text-xs text-primary-container border border-primary-container/30 px-4 py-2 rounded hover:bg-primary-container/10 transition-all" onclick="goTo('booking')">AGENDAR</button>
      </div>
    </div>
  </header>

  <!-- ===== LANDING PAGE (STITCH ELITE) ===== -->
  <div id="landing" class="screen active">
    <main>
      <!-- Hero -->
      <section class="relative h-screen flex items-center justify-center overflow-hidden">
        <div class="absolute inset-0 z-0">
          <img class="w-full h-full object-cover grayscale opacity-40 contrast-125" src="https://lh3.googleusercontent.com/aida-public/AB6AXuChIi426DWTOFonRoR9VOojHh2mrhlB2ZhULmIdizPCl737Esm65BiT622KmhMWyXV2Q1fLPCyOXuKvJrFBcD4q3DutQnSeM3SMC5vpTc1MRreAQ25aVyZfXwqXYWMbPxycJpPZe1uQbpjGYwmgxExXhcoeCPJXXj92DvXglyJlWC5G65ZxJE_LAiUMc99f0UHecnTCw0s3sWJ06WdIB-Vb_3-314QB1-gu7Tc2ze-v4bO89_d3rIzYg__nAXQ09I-gekA56XIkqs6z"/>
          <div class="absolute inset-0 bg-gradient-to-t from-background via-transparent to-transparent"></div>
        </div>
        <div class="relative z-10 text-center max-w-4xl px-8">
          <div class="mb-6 inline-flex items-center gap-2 px-4 py-1 glass-panel text-primary-container font-bold text-[10px] uppercase tracking-widest rounded-full">
            <span class="w-2 h-2 bg-primary-container rounded-full animate-pulse"></span>
            Precisão Digital. Mestria Artesanal.
          </div>
          <h1 class="font-serif text-5xl md:text-8xl text-white mb-6 uppercase leading-tight italic tracking-tighter">Mestria em <span class="text-primary-container">Grooming</span></h1>
          <p class="font-sans text-lg text-zinc-400 mb-10 max-w-2xl mx-auto font-light leading-relaxed">
            Combinamos a tradição da barbearia clássica com tecnologia de ponta para criar experiências de cuidado pessoal incomparáveis.
          </p>
          <div class="flex flex-col md:flex-row gap-4 justify-center">
            <button class="bg-primary-container text-on-primary-container px-12 py-5 font-bold text-xs uppercase tracking-widest hover:brightness-110 active:scale-95 transition-all rounded" onclick="goTo('booking')">Marcar Agora</button>
            <button class="glass-panel text-white px-12 py-5 font-bold text-xs uppercase tracking-widest border border-white/10 hover:bg-white/5 transition-all rounded" onclick="goTo('client-login')">Ver Meus Horários</button>
          </div>
        </div>
      </section>

      <!-- History -->
      <section class="py-32 relative overflow-hidden bg-surface-container-lowest">
        <div class="max-w-7xl mx-auto px-8 relative z-10">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-20 items-center">
            <div class="relative">
              <div class="absolute -top-4 -left-4 w-24 h-24 border-t-2 border-l-2 border-primary-container opacity-30"></div>
              <div class="aspect-[4/5] overflow-hidden rounded-lg">
                <img class="w-full h-full object-cover grayscale brightness-75 hover:scale-105 transition-transform duration-700" src="https://lh3.googleusercontent.com/aida-public/AB6AXuB02V84GF1iQ74mCTBdc45elE1ZN61N8nTRf5M_I3Ci3AuVTPtutHl9zaBocKmGhsSskqK5q0-YoOhNgXGln3U9ktM893znxiBRPuyAyayEvB50-oOLQxIvhLpfuhfEEZwwulbNbvi7-zfavFT9t1IggfrUSMVYqUFrJEVj0NxqPg5ft816IGlEJ8zJDJQCQL-0T1UEdhuO4EyisEBRZ53blbcoTJZK9ib0lDNJ7bYUdBwOiaMZ6EvJVvc6bB9hcrtOD_p3HfVapVqV"/>
              </div>
            </div>
            <div>
              <span class="text-primary-container font-sans text-xs font-bold uppercase tracking-[0.3em] mb-4 block italic">Herança & Inovação</span>
              <h2 class="font-serif text-4xl md:text-6xl text-white mb-8 uppercase leading-tight italic tracking-tighter">Nossa História: <br/><span class="text-primary-container">Legado de Ferro</span></h2>
              <p class="font-sans text-zinc-400 mb-12 font-light leading-relaxed text-lg">
                Desde 2012, o BarberPro tem redefinido os padrões de estética masculina. Nascemos da necessidade de criar um refúgio onde a técnica manual se encontra com a inovação digital. Não cortamos apenas cabelo; calibramos identidades.
              </p>
              <div class="grid grid-cols-2 gap-12 mb-12">
                <div>
                  <div class="text-5xl font-black text-white mb-2 tracking-tighter italic">12K+</div>
                  <div class="text-primary-container font-sans text-[10px] uppercase tracking-widest font-bold">Sessões Realizadas</div>
                </div>
                <div>
                  <div class="text-5xl font-black text-white mb-2 tracking-tighter italic">98%</div>
                  <div class="text-primary-container font-sans text-[10px] uppercase tracking-widest font-bold">ÃƒÂndice de Precisão</div>
                </div>
              </div>
              <button class="flex items-center gap-4 text-white font-bold text-xs uppercase tracking-widest group" onclick="goTo('booking')">
                Marcar Experiência <span class="material-symbols-outlined text-primary-container group-hover:translate-x-3 transition-transform">trending_flat</span>
              </button>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="bg-surface-container-lowest border-t border-white/5 py-20">
      <div class="max-w-7xl mx-auto px-8 flex flex-col md:flex-row justify-between items-center gap-8">
        <div class="text-white font-black uppercase tracking-tighter text-2xl italic font-serif">BarberPro</div>
        <div class="font-sans text-[10px] tracking-widest uppercase text-zinc-600">
          © 2024 BarberPro TECHNOLOGIES. PRECISION ENGINEERED.
        </div>
        <div class="flex gap-8">
          <a href="#" class="text-[10px] text-zinc-600 uppercase tracking-widest hover:text-white transition-colors">Instagram</a>
          <a href="#" class="text-[10px] text-zinc-600 uppercase tracking-widest hover:text-white transition-colors">Spotify</a>
        </div>
      </div>
    </footer>
  </div>

  <!-- ===== LOGIN (ELITE) ===== -->
  <div id="login" class="screen">
    <div class="min-h-screen flex items-center justify-center px-4 py-12 relative overflow-hidden">
      <div class="absolute inset-0 z-0">
        <div class="absolute top-0 left-0 w-96 h-96 bg-primary-container/10 rounded-full blur-[100px]"></div>
        <div class="absolute bottom-0 right-0 w-96 h-96 bg-white/5 rounded-full blur-[100px]"></div>
      </div>
      <div class="relative z-10 w-full max-w-md glass-panel p-10 rounded-xl space-y-8 border-t border-white/10 shadow-2xl">
        <div class="text-center space-y-2">
          <div class="text-3xl font-serif font-black text-white tracking-tighter italic uppercase">BarberPro</div>
          <p class="text-primary-container font-sans text-[10px] font-bold uppercase tracking-[0.2em]">Painel do Barbeiro</p>
        </div>
        
        <div class="flex border-b border-white/10 mb-8">
          <button class="flex-1 py-3 text-xs font-bold uppercase tracking-widest text-white border-b-2 border-primary-container" id="login-tab-btn" onclick="switchTab('login-tab','register-tab',this)">Entrar</button>
          <button class="flex-1 py-3 text-xs font-bold uppercase tracking-widest text-zinc-500 hover:text-white transition-colors" id="register-tab-btn" onclick="switchTab('register-tab','login-tab',this)">Cadastrar</button>
        </div>

        <div id="login-tab" class="space-y-6">
          <div class="space-y-2">
            <label class="text-zinc-500 uppercase text-[10px] font-bold tracking-widest">E-mail</label>
            <input type="email" id="login-email" class="w-full bg-white/5 border border-white/10 rounded p-4 text-white focus:border-primary-container outline-none transition-all" placeholder="seu@email.com">
          </div>
          <div class="space-y-2">
            <label class="text-zinc-500 uppercase text-[10px] font-bold tracking-widest">Senha</label>
            <input type="password" id="login-pass" class="w-full bg-white/5 border border-white/10 rounded p-4 text-white focus:border-primary-container outline-none transition-all" placeholder="••••••••">
          </div>
          <button class="w-full bg-primary-container text-on-primary-container py-5 font-bold uppercase tracking-widest hover:brightness-110 transition-all rounded" onclick="doLogin()">Entrar no Dashboard</button>
        </div>

        <div id="register-tab" class="hidden space-y-6">
          <div class="space-y-2">
            <label class="text-zinc-500 uppercase text-[10px] font-bold tracking-widest">Nome da Barbearia</label>
            <input type="text" id="reg-name" class="w-full bg-white/5 border border-white/10 rounded p-4 text-white focus:border-primary-container outline-none transition-all" placeholder="Minha Barbearia">
          </div>
          <div class="space-y-2">
            <label class="text-zinc-500 uppercase text-[10px] font-bold tracking-widest">Seu Nome</label>
            <input type="text" id="reg-user" class="w-full bg-white/5 border border-white/10 rounded p-4 text-white focus:border-primary-container outline-none transition-all" placeholder="Nome Sobrenome">
          </div>
          <div class="space-y-2">
            <label class="text-zinc-500 uppercase text-[10px] font-bold tracking-widest">E-mail</label>
            <input type="email" id="reg-email" class="w-full bg-white/5 border border-white/10 rounded p-4 text-white focus:border-primary-container outline-none transition-all" placeholder="seu@email.com">
          </div>
          <div class="space-y-2">
            <label class="text-zinc-500 uppercase text-[10px] font-bold tracking-widest">Senha</label>
            <input type="password" id="reg-pass" class="w-full bg-white/5 border border-white/10 rounded p-4 text-white focus:border-primary-container outline-none transition-all" placeholder="••••••••">
          </div>
          <button class="w-full bg-primary-container text-on-primary-container py-5 font-bold uppercase tracking-widest hover:brightness-110 transition-all rounded" onclick="doRegister()">Criar Conta Grátis</button>
        </div>

        <div class="text-center pt-4">
          <button class="text-zinc-600 uppercase text-[10px] font-bold tracking-widest hover:text-white transition-colors" onclick="goTo('landing')">← Voltar para o Início</button>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== BOOKING SCREEN (STITCH ELITE) ===== -->
  <div id="booking" class="screen">
    <main class="pt-24 pb-32 min-h-screen px-4 md:px-8 max-w-7xl mx-auto flex flex-col md:flex-row gap-12">
      <!-- Left Column: Step Content -->
      <div class="flex-grow space-y-12">
        <!-- Stepper Progress Indicator -->
        <div class="flex items-center gap-4 overflow-x-auto pb-4 scrollbar-hide">
          <div class="flex items-center gap-3 shrink-0">
            <span class="w-8 h-8 rounded-full border border-primary-container flex items-center justify-center text-primary-container font-sans text-xs font-bold" id="si-1">1</span>
            <span class="font-sans text-white uppercase tracking-widest text-[10px] font-bold">Serviço</span>
          </div>
          <div class="h-[1px] w-8 bg-white/10"></div>
          <div class="flex items-center gap-3 shrink-0">
            <span class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center text-zinc-500 font-sans text-xs" id="si-2">2</span>
            <span class="font-sans text-zinc-500 uppercase tracking-widest text-[10px]">Horário</span>
          </div>
          <div class="h-[1px] w-8 bg-white/10"></div>
          <div class="flex items-center gap-3 shrink-0">
            <span class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center text-zinc-500 font-sans text-xs" id="si-3">3</span>
            <span class="font-sans text-zinc-500 uppercase tracking-widest text-[10px]">Confirmação</span>
          </div>
        </div>

        <!-- Section: Services & Barbers (Step 1) -->
        <div id="step1" class="booking-step active space-y-8">
          <div class="space-y-2">
            <h1 class="font-serif text-4xl md:text-6xl text-white uppercase italic tracking-tighter">Escolha o seu <span class="text-primary-container">Serviço</span></h1>
            <p class="text-zinc-400 font-sans text-lg font-light max-w-xl">Selecione uma das nossas especialidades de engenharia capilar.</p>
          </div>
          <div id="booking-services" class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <!-- Dynamic Services Load Here -->
          </div>
          
          <div class="space-y-2 pt-12">
            <h2 class="font-serif text-3xl md:text-5xl text-white uppercase italic tracking-tighter">Escolha o <span class="text-primary-container">Mestre</span></h2>
            <p class="text-zinc-400 font-sans text-lg font-light max-w-xl">Selecione seu profissional de preferência.</p>
          </div>
          <div id="booking-barbers" class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <!-- Dynamic Barbers Load Here -->
          </div>

          <div class="flex justify-end pt-8">
            <button class="bg-primary-container text-on-primary-container font-sans font-bold px-10 py-5 uppercase tracking-widest flex items-center gap-3 rounded-lg hover:brightness-110 active:scale-95 transition-all" id="btn-step1" onclick="nextStep(2)" disabled>
              Próximo Passo
              <span class="material-symbols-outlined">arrow_forward</span>
            </button>
          </div>
        </div>

        <!-- Section: Schedule (Step 2) -->
        <div id="step2" class="booking-step hidden space-y-8">
          <div class="space-y-2">
            <h1 class="font-serif text-4xl md:text-6xl text-white uppercase italic tracking-tighter">Calibração de <span class="text-primary-container">Horário</span></h1>
            <p class="text-zinc-400 font-sans text-lg font-light max-w-xl">Selecione o momento ideal para sua transformação.</p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
            <div class="glass-panel p-6 rounded-lg">
              <div class="calendar-nav flex justify-between items-center mb-6">
                <button class="text-primary-container" onclick="changeMonth(-1)"><span class="material-symbols-outlined">chevron_left</span></button>
                <span class="font-serif text-xl text-white uppercase italic" id="cal-month-label">Janeiro</span>
                <button class="text-primary-container" onclick="changeMonth(1)"><span class="material-symbols-outlined">chevron_right</span></button>
              </div>
              <div class="grid grid-cols-7 gap-2 text-center text-[10px] text-zinc-600 font-bold uppercase mb-4">
                <span>Dom</span><span>Seg</span><span>Ter</span><span>Qua</span><span>Qui</span><span>Sex</span><span>Sab</span>
              </div>
              <div id="cal-grid" class="grid grid-cols-7 gap-2">
                <!-- Calendar Grid -->
              </div>
            </div>
            <div class="space-y-6">
              <h3 class="font-sans text-xs font-bold text-zinc-500 uppercase tracking-widest" id="time-title">Horários Disponíveis</h3>
              <div id="time-slots" class="grid grid-cols-3 gap-3">
                <!-- Dynamic Times Load Here -->
              </div>
            </div>
          </div>
          <div class="flex justify-between pt-8">
            <button class="text-zinc-500 uppercase text-xs font-bold tracking-widest hover:text-white transition-colors" onclick="nextStep(1)">← Voltar aos Serviços</button>
            <button class="bg-primary-container text-on-primary-container font-sans font-bold px-10 py-5 uppercase tracking-widest flex items-center gap-3 rounded-lg hover:brightness-110 active:scale-95 transition-all" id="btn-step2" onclick="nextStep(3)" disabled>
              Avançar
              <span class="material-symbols-outlined">arrow_forward</span>
            </button>
          </div>
        </div>

        <!-- Section: Confirm (Step 3) -->
        <div id="step3" class="booking-step hidden space-y-8">
          <div class="space-y-2">
            <h1 class="font-serif text-4xl md:text-6xl text-white uppercase italic tracking-tighter">Finalizar <span class="text-primary-container">Reserva</span></h1>
            <p class="text-zinc-400 font-sans text-lg font-light max-w-xl">Confirme os detalhes do seu ritual.</p>
          </div>
          
          <div id="vip-booking-banner" class="hidden glass-panel p-6 border-l-4 border-primary-container rounded-r-lg">
            <div class="flex items-center gap-4">
              <span class="material-symbols-outlined text-primary-container">verified</span>
              <div>
                <p class="font-serif text-white uppercase italic">Assinante VIP</p>
                <p class="text-zinc-400 text-sm">Identificamos seu plano ativo. A reserva será processada automaticamente.</p>
              </div>
            </div>
          </div>

          <div class="glass-panel p-8 rounded-lg space-y-8">
            <div id="booking-summary" class="space-y-4">
              <!-- Dynamic Details Load Here -->
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="form-group">
                <label class="text-zinc-500 uppercase text-[10px] font-bold tracking-widest block mb-2">Identificação</label>
                <input type="text" id="client-name" class="w-full bg-white/5 border border-white/10 rounded p-4 text-white focus:border-primary-container outline-none transition-all placeholder:text-zinc-700" placeholder="Seu nome completo">
              </div>
              <div class="form-group">
                <label class="text-zinc-500 uppercase text-[10px] font-bold tracking-widest block mb-2">Contato WhatsApp</label>
                <input type="tel" id="client-phone" class="w-full bg-white/5 border border-white/10 rounded p-4 text-white focus:border-primary-container outline-none transition-all placeholder:text-zinc-700" placeholder="(00) 00000-0000">
              </div>
            </div>

            <div class="space-y-4">
              <h3 class="font-serif text-xl text-white uppercase italic">Forma de Liquidação</h3>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div id="pay-shop" class="glass-panel p-6 rounded-lg cursor-pointer border-2 border-transparent hover:border-primary-container/30 transition-all flex justify-between items-center group" onclick="selectPayment('shop')">
                  <div>
                    <p class="text-white font-bold uppercase text-xs tracking-widest">Presencial</p>
                    <p class="text-zinc-500 text-[10px] uppercase">No Atelier</p>
                  </div>
                  <span class="material-symbols-outlined text-zinc-500 group-hover:text-primary-container">payments</span>
                </div>
                <div id="pay-pix" class="glass-panel p-6 rounded-lg cursor-pointer border-2 border-transparent hover:border-primary-container/30 transition-all flex justify-between items-center group" onclick="selectPayment('pix')">
                  <div>
                    <p class="text-white font-bold uppercase text-xs tracking-widest">Digital (Pix)</p>
                    <p class="text-zinc-500 text-[10px] uppercase">Imediato</p>
                  </div>
                  <span class="material-symbols-outlined text-zinc-500 group-hover:text-primary-container">qr_code_2</span>
                </div>
              </div>
            </div>

            <button class="w-full bg-primary-container text-on-primary-container py-6 font-bold uppercase tracking-widest hover:brightness-110 transition-all rounded shadow-[0_0_30px_rgba(212,175,55,0.2)]" onclick="confirmBooking()">Ã¢Å“â€ Confirmar Experiência</button>
          </div>
          <button class="text-zinc-500 uppercase text-xs font-bold tracking-widest hover:text-white transition-colors" onclick="nextStep(2)">← Revisar Detalhes</button>
        </div>

        <!-- Section: Success (Step 4) -->
        <div id="step4" class="booking-step hidden space-y-12 text-center py-20">
          <div class="relative inline-block">
            <div class="absolute inset-0 bg-primary-container blur-[40px] opacity-20"></div>
            <span class="material-symbols-outlined text-8xl text-primary-container relative z-10" style="font-variation-settings: 'FILL' 1;">check_circle</span>
          </div>
          <div class="space-y-4">
            <h1 class="font-serif text-5xl md:text-7xl text-white uppercase italic tracking-tighter">Sua vaga está <span class="text-primary-container">Garantida</span>.</h1>
            <p class="text-zinc-400 font-sans text-xl font-light max-w-2xl mx-auto">A precisão do nosso trabalho agora aguarda sua presença.</p>
          </div>
