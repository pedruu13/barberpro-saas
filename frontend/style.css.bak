/* 
  ELITE NOIR DESIGN SYSTEM 
  Design by Stitch - Optimized for BarberPro
*/

:root {
  --gold: #D4AF37;
  --gold-dark: #B8860B;
  --bg: #121414;
  --bg-card: #1A1C1C;
  --bg-elevated: #242626;
  --border-color: rgba(255, 255, 255, 0.08);
  --text: #F8F9FA;
  --text-dim: #A0A0A0;
  --white-dim: rgba(255, 255, 255, 0.6);
  --green: #10B981;
  --red: #EF4444;
  --shadow-sm: 0 4px 6px -1px rgba(0, 0, 0, 0.3);
  --shadow-lg: 0 20px 25px -5px rgba(0, 0, 0, 0.5);
  --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

/* Base Reset */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  -webkit-tap-highlight-color: transparent;
}

body {
  font-family: 'Manrope', sans-serif;
  background-color: var(--bg);
  color: var(--text);
  line-height: 1.6;
  overflow-x: hidden;
}

h1, h2, h3, .nav-logo {
  font-family: 'Cormorant Garamond', serif;
}

/* Scrollbar */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: #333; border-radius: 10px; }
::-webkit-scrollbar-thumb:hover { background: var(--gold); }

/* Screens Navigation */
.screen {
  display: none;
  min-height: 100vh;
  opacity: 0;
}
.screen.active {
  display: block;
  animation: fadeIn 0.5s forwards;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Glassmorphism */
.glass-card {
  background: rgba(26, 28, 28, 0.7);
  backdrop-filter: blur(12px);
  border: 1px solid var(--border-color);
  border-radius: 16px;
  box-shadow: var(--shadow-lg);
}

/* Buttons */
.btn-full {
  width: 100%;
  padding: 14px;
  border-radius: 10px;
  border: none;
  background: var(--gold);
  color: #000;
  font-weight: 700;
  font-size: 16px;
  cursor: pointer;
  transition: var(--transition);
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-full:hover {
  background: var(--gold-dark);
  transform: translateY(-2px);
  box-shadow: 0 8px 15px rgba(212, 175, 55, 0.2);
}
.btn-full:active { transform: translateY(0); }

.btn-sm {
  padding: 8px 16px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  transition: var(--transition);
  border: 1px solid var(--border-color);
  background: rgba(255,255,255,0.05);
  color: #fff;
}
.btn-sm-gold {
  background: var(--gold);
  color: #000;
  border: none;
}
.btn-sm-ghost {
  background: transparent;
  border: 1px solid var(--border-color);
  color: var(--text-dim);
}
.btn-sm:hover { transform: translateY(-1px); opacity: 0.9; }

/* ── LANDING PAGE (PORTAL) ────────────────────── */
.main-nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  height: 80px;
  z-index: 100;
  background: rgba(18, 20, 20, 0.8);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid var(--border-color);
}
.nav-container {
  max-width: 1200px;
  margin: 0 auto;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24px;
}
.nav-logo {
  font-size: 28px;
  font-weight: 700;
  color: #fff;
  cursor: pointer;
}
.nav-logo span { color: var(--gold); }

.nav-links {
  display: flex;
  align-items: center;
  gap: 30px;
}
.nav-links a {
  text-decoration: none;
  color: var(--white-dim);
  font-size: 14px;
  font-weight: 500;
  transition: var(--transition);
}
.nav-links a:hover { color: var(--gold); }

.btn-nav-login {
  background: transparent;
  border: none;
  color: #fff;
  font-weight: 600;
  font-size: 14px;
  cursor: pointer;
}
.btn-nav-cta {
  background: var(--gold);
  color: #000;
  border: none;
  padding: 10px 20px;
  border-radius: 8px;
  font-weight: 700;
  font-size: 14px;
  cursor: pointer;
  transition: var(--transition);
}

/* Hero Section */
.hero-section {
  position: relative;
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 0 24px;
}
.hero-bg {
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  z-index: -1;
}
.hero-bg img { width: 100%; height: 100%; object-fit: cover; }
.hero-overlay {
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  background: linear-gradient(0deg, var(--bg) 0%, rgba(18,20,20,0.6) 50%, var(--bg) 100%);
}

.hero-content {
  max-width: 800px;
  z-index: 10;
}
.badge-hero {
  display: inline-block;
  padding: 6px 16px;
  background: rgba(212, 175, 55, 0.1);
  border: 1px solid var(--gold);
  border-radius: 20px;
  color: var(--gold);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 1px;
  margin-bottom: 24px;
  animation: slideInDown 1s forwards;
}
.hero-title {
  font-size: clamp(40px, 8vw, 72px);
  line-height: 1.1;
  margin-bottom: 24px;
  color: #fff;
}
.hero-title span { color: var(--gold); }
.hero-subtitle {
  font-size: 18px;
  color: var(--white-dim);
  margin-bottom: 48px;
}

.hero-cta-group {
  display: flex;
  gap: 20px;
  justify-content: center;
  flex-wrap: wrap;
}

.hero-cta-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid var(--border-color);
  backdrop-filter: blur(10px);
  padding: 20px;
  border-radius: 16px;
  width: 280px;
  text-align: left;
  display: flex;
  align-items: center;
  gap: 16px;
  cursor: pointer;
  transition: var(--transition);
}
.hero-cta-card:hover {
  background: rgba(255, 255, 255, 0.1);
  border-color: var(--gold);
  transform: translateY(-5px);
}
.card-icon {
  font-size: 32px;
  width: 60px;
  height: 60px;
  background: var(--bg-elevated);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.card-text h3 { font-size: 18px; color: #fff; margin-bottom: 4px; }
.card-text p { font-size: 12px; color: var(--text-dim); line-height: 1.3; }
.card-arrow { margin-left: auto; color: var(--gold); font-size: 20px; opacity: 0; transition: var(--transition); }
.hero-cta-card:hover .card-arrow { opacity: 1; transform: translateX(5px); }

/* Ribbon */
.stats-ribbon {
  display: flex;
  justify-content: center;
  gap: 60px;
  padding: 40px 24px;
  background: var(--bg-card);
  border-top: 1px solid var(--border-color);
  flex-wrap: wrap;
}
.stat-item { font-size: 14px; color: var(--white-dim); }
.stat-item strong { color: var(--gold); font-size: 20px; margin-right: 8px; }

/* ── BOOKING SCREEN (AGENDAMENTO) ──────────────── */
.booking-container {
  max-width: 1000px;
  margin: 0 auto;
  padding: 0 20px 100px;
}

.booking-header {
  position: sticky;
  top: 0;
  z-index: 50;
  padding: 24px 0;
  margin-bottom: 40px;
  background: var(--bg);
}
.booking-header-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20px;
  border-bottom: 1px solid var(--border-color);
}
.booking-brand h1 { font-size: 32px; margin-bottom: 4px; }
.booking-brand h1 span { color: var(--gold); }
.booking-brand p { font-size: 12px; color: var(--gold); text-transform: uppercase; letter-spacing: 2px; }

.booking-steps { display: flex; gap: 12px; }
.step-indicator {
  width: 32px; height: 32px;
  border-radius: 50%;
  border: 1px solid var(--border-color);
  display: flex; align-items: center; justify-content: center;
  font-size: 14px; font-weight: 700; color: var(--text-dim);
  transition: var(--transition);
}
.step-indicator.active {
  background: var(--gold);
  border-color: var(--gold);
  color: #000;
}
.step-indicator.done {
  background: #fff;
  border-color: #fff;
  color: #000;
}

.step-panel { display: none; }
.step-panel.active { display: block; animation: slideInUp 0.6s forwards; }

.step-title-wrap { margin-bottom: 32px; }
.step-title { font-size: 32px; color: #fff; margin-bottom: 8px; }
.step-desc { color: var(--text-dim); font-size: 15px; }

/* Services Grid */
.services-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 16px;
}

.service-card {
  background: var(--bg-card);
  border: 1px solid var(--border-color);
  border-radius: 16px;
  padding: 20px;
  display: flex;
  justify-content: space-between;
  cursor: pointer;
  transition: var(--transition);
}
.service-card:hover { border-color: rgba(212, 175, 55, 0.4); transform: translateY(-3px); }
.service-card.selected { border-color: var(--gold); background: rgba(212, 175, 55, 0.05); }

.service-info h4 { font-size: 18px; color: #fff; margin-bottom: 6px; }
.service-meta { font-size: 12px; color: var(--text-dim); }

.service-right { text-align: right; display: flex; flex-direction: column; justify-content: space-between; }
.service-price { color: var(--gold); font-weight: 800; font-size: 18px; }
.service-check { 
  width: 24px; height: 24px; 
  border-radius: 50%; 
  border: 1px solid var(--border-color); 
  display: flex; align-items: center; justify-content: center;
  font-size: 12px;
}
.service-card.selected .service-check { background: var(--gold); color: #000; border-color: var(--gold); }

/* Svc Sticky Bar */
.svc-bar {
  position: fixed;
  bottom: 24px; left: 50%;
  transform: translateX(-50%) translateY(100px);
  width: calc(100% - 40px);
  max-width: 600px;
  background: #fff;
  border-radius: 50px;
  padding: 8px 8px 8px 32px;
  display: flex;
  z-index: 100;
  box-shadow: 0 20px 40px rgba(0,0,0,0.4);
  transition: transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}
.svc-bar.visible { transform: translateX(-50%) translateY(0); }

.svc-bar-content { width: 100%; display: flex; align-items: center; justify-content: space-between; }
.svc-bar-info { display: flex; flex-direction: column; }
.svc-bar-info span { font-size: 12px; color: #666; font-weight: 600; }
.svc-bar-info strong { font-size: 20px; color: #000; font-weight: 800; }

.btn-step-next {
  background: #000;
  color: #fff;
  border: none;
  padding: 14px 28px;
  border-radius: 40px;
  font-weight: 700;
  cursor: pointer;
  transition: var(--transition);
}
.btn-step-next:hover { opacity: 0.9; }

/* ── DASHBOARD ADMIN ─────────────────────────── */
.admin-wrapper {
  display: flex;
  min-height: 100vh;
}

.admin-sidebar {
  width: 280px;
  background: #0F1010;
  border-right: 1px solid var(--border-color);
  padding: 32px 20px;
  display: flex;
  flex-direction: column;
  position: sticky;
  top: 0; height: 100vh;
}

.sidebar-header { margin-bottom: 40px; }
.sidebar-user {
  background: var(--bg-card);
  border-radius: 16px;
  padding: 16px;
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 40px;
}
.sidebar-avatar {
  width: 44px; height: 44px;
  background: var(--bg-elevated);
  border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  font-size: 20px;
}
.sidebar-user-name { display: block; font-size: 14px; font-weight: 700; color: #fff; }
.sidebar-user-status { font-size: 11px; color: var(--gold); text-transform: uppercase; font-weight: 800; }

.nav-group {
  font-size: 11px;
  text-transform: uppercase;
  color: var(--text-dim);
  letter-spacing: 1px;
  margin: 24px 0 12px 12px;
  font-weight: 700;
}

.nav-item {
  width: 100%;
  padding: 12px 16px;
  border-radius: 10px;
  background: transparent;
  border: none;
  color: var(--white-dim);
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: var(--transition);
  text-align: left;
}
.nav-item span { font-size: 18px; }
.nav-item:hover { background: rgba(255,255,255,0.03); color: #fff; }
.nav-item.active { background: rgba(212, 175, 55, 0.1); color: var(--gold); }

.admin-main { flex: 1; }

.admin-topbar {
  height: 80px;
  border-bottom: 1px solid var(--border-color);
  padding: 0 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(18, 20, 20, 0.5);
  backdrop-filter: blur(10px);
}
.topbar-left { display: flex; align-items: center; gap: 16px; }
.topbar-left h2 { font-size: 24px; color: #fff; }

.topbar-user-pill {
  background: var(--bg-card);
  padding: 6px 16px;
  border-radius: 20px;
  display: flex; align-items: center; gap: 10px;
  font-size: 13px; font-weight: 600;
  border: 1px solid var(--border-color);
}
.user-status-dot { width: 8px; height: 8px; background: var(--green); border-radius: 50%; box-shadow: 0 0 10px var(--green); }

.admin-content { padding: 40px; }

/* Dashboard Grid */
.dashboard-grid {
  display: grid;
  grid-template-columns: repeat(12, 1fr);
  gap: 24px;
}

.stat-card {
  grid-column: span 3;
  background: var(--bg-card);
  border: 1px solid var(--border-color);
  border-radius: 20px;
  padding: 24px;
}
.stat-card-label { font-size: 13px; color: var(--text-dim); margin-bottom: 8px; }
.stat-card-value { font-size: 32px; font-weight: 800; color: #fff; margin-bottom: 8px; }
.stat-card-trend { font-size: 12px; color: var(--green); font-weight: 600; }
.stat-card-trend.down { color: var(--red); }

.section-card {
  grid-column: span 6;
  background: var(--bg-card);
  border: 1px solid var(--border-color);
  border-radius: 24px;
  overflow: hidden;
}
.appt-section { grid-column: span 8; }
.chart-section { grid-column: span 4; }
.services-dash { grid-column: span 4; }
.link-section { grid-column: span 4; }

.section-card-header {
  padding: 24px 24px 16px;
  display: flex; justify-content: space-between; align-items: center;
  border-bottom: 1px solid var(--border-color);
}
.section-card-header span { font-weight: 800; color: #fff; font-size: 15px; }

/* Appt List Admin */
.admin-appt-list { padding: 8px 0; }
.appt-item {
  padding: 16px 24px;
  display: flex; align-items: center;
  border-bottom: 1px solid rgba(255,255,255,0.03);
  transition: var(--transition);
}
.appt-item:last-child { border: none; }
.appt-item:hover { background: rgba(255,255,255,0.02); }

.appt-time { font-weight: 800; color: #fff; margin-right: 20px; min-width: 50px; }
.appt-dot { width: 10px; height: 10px; border-radius: 50%; margin-right: 20px; }
.appt-info { flex: 1; }
.appt-client { font-weight: 700; color: #fff; font-size: 15px; }
.appt-service { font-size: 12px; color: var(--text-dim); }
.appt-barber-badge { 
  background: rgba(212, 175, 55, 0.1); 
  color: var(--gold); 
  padding: 4px 10px; 
  border-radius: 6px; 
  font-size: 11px; 
  font-weight: 800;
  margin-left: 10px;
}

.appt-actions { display: flex; gap: 8px; margin-left: 20px; }
.btn-icon {
  width: 32px; height: 32px;
  border-radius: 8px;
  border: 1px solid var(--border-color);
  background: transparent;
  color: var(--white-dim);
  cursor: pointer;
  transition: var(--transition);
  display: flex; align-items: center; justify-content: center;
}
.btn-icon:hover { border-color: #fff; color: #fff; }
.btn-icon.status-done:hover { background: var(--green); color: #000; border-color: var(--green); }
.btn-icon.status-miss:hover { background: var(--red); color: #fff; border-color: var(--red); }
.btn-icon.danger:hover { background: var(--red); color: #fff; border-color: var(--red); }

/* ── CALENDAR COMPONENT ──────────────────────── */
.calendar-card {
  background: var(--bg-elevated);
  border-radius: 20px;
  padding: 24px;
  margin-bottom: 24px;
}
.cal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
.cal-header button { 
  background: transparent; border: 1px solid var(--border-color); 
  width: 36px; height: 36px; border-radius: 10px; color: #fff; cursor: pointer;
}
.cal-month-label { font-weight: 800; font-size: 16px; }

.cal-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8px;
}
.cal-day-label { text-align: center; font-size: 11px; color: var(--text-dim); text-transform: uppercase; font-weight: 700; margin-bottom: 8px; }
.cal-day {
  height: 44px;
  display: flex; align-items: center; justify-content: center;
  border-radius: 10px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: var(--transition);
  color: var(--white-dim);
}
.cal-day:hover:not(.empty):not(.past) { background: rgba(255,255,255,0.1); color: #fff; }
.cal-day.selected { background: var(--gold); color: #000; font-weight: 800; }
.cal-day.today { border: 1px solid var(--gold); color: var(--gold); }
.cal-day.past { opacity: 0.2; cursor: default; }
.cal-day.empty { cursor: default; }

/* ── MODALS ──────────────────────────────────── */
.modal-overlay {
  position: fixed;
  top: 0; left: 0; width: 100%; height: 100%;
  background: rgba(0,0,0,0.8);
  backdrop-filter: blur(8px);
  z-index: 1000;
  display: none;
  align-items: center;
  justify-content: center;
  padding: 20px;
}
.modal-overlay.open { display: flex; }

.modal {
  background: var(--bg-card);
  border: 1px solid var(--border-color);
  width: 100%;
  max-width: 480px;
  border-radius: 24px;
  padding: 32px;
  animation: modalScale 0.3s forwards;
}
@keyframes modalScale {
  from { transform: scale(0.9); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
.modal-title { font-size: 24px; color: #fff; }
.modal-close { background: transparent; border: none; color: var(--text-dim); font-size: 28px; cursor: pointer; }

.form-group { margin-bottom: 20px; }
.form-group label { display: block; font-size: 13px; color: var(--text-dim); margin-bottom: 8px; font-weight: 600; }
.form-group input, .form-group select {
  width: 100%;
  padding: 14px 16px;
  background: var(--bg-elevated);
  border: 1px solid var(--border-color);
  border-radius: 12px;
  color: #fff;
  font-family: inherit;
  font-size: 15px;
  outline: none;
  transition: var(--transition);
}
.form-group input:focus { border-color: var(--gold); box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.1); }

/* ── MOBILE NAV ─────────────────────────────── */
.nav-mobile-dropdown {
  position: fixed;
  top: 80px; left: 0; width: 100%;
  background: var(--bg);
  border-bottom: 1px solid var(--border-color);
  padding: 20px;
  display: none;
  flex-direction: column;
  gap: 16px;
  z-index: 99;
  transform: translateY(-100%);
  transition: transform 0.3s ease;
}
.nav-mobile-dropdown.open { display: flex; transform: translateY(0); }

/* ── TOAST ───────────────────────────────────── */
.toast {
  position: fixed;
  bottom: 30px; left: 50%;
  transform: translateX(-50%) translateY(100px);
  background: #fff;
  color: #000;
  padding: 12px 24px;
  border-radius: 12px;
  font-weight: 700;
  font-size: 14px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.5);
  z-index: 2000;
  transition: transform 0.3s ease;
}
.toast.show { transform: translateX(-50%) translateY(0); }

/* responsive adjustments */
@media (max-width: 1024px) {
  .admin-sidebar { display: none; }
  .stat-card { grid-column: span 6; }
  .appt-section, .chart-section, .services-dash, .link-section { grid-column: span 12; }
  .admin-topbar { padding: 0 20px; }
  .hero-cta-group { flex-direction: column; align-items: center; }
}

@media (max-width: 768px) {
  .hero-title { font-size: 40px; }
  .stat-card { grid-column: span 12; }
  .booking-header-content { flex-direction: column; gap: 20px; align-items: flex-start; }
  .selection-grid { display: block; }
  .cal-grid { gap: 4px; }
  .cal-day { height: 38px; font-size: 12px; }
}

/* Animations */
@keyframes slideInUp {
  from { transform: translateY(20px); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}
@keyframes slideInDown {
  from { transform: translateY(-20px); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

/* Auth Cards */
.auth-container {
  min-height: 100vh;
  display: flex; align-items: center; justify-content: center;
  padding: 24px;
  background: radial-gradient(circle at top right, rgba(212,175,55,0.1), transparent);
}
.auth-card {
  width: 100%; max-width: 440px;
  padding: 40px;
}
.auth-header { text-align: center; margin-bottom: 32px; }
.auth-logo { font-size: 36px; font-weight: 700; color: #fff; margin-bottom: 24px; cursor: pointer; }
.auth-logo span { color: var(--gold); }
.auth-tabs { display: flex; gap: 10px; background: rgba(0,0,0,0.2); padding: 6px; border-radius: 12px; }
.auth-tab {
  flex: 1; padding: 10px; border: none; background: transparent; 
  color: var(--text-dim); font-weight: 700; font-size: 13px; cursor: pointer; border-radius: 8px;
}
.auth-tab.active { background: var(--bg-elevated); color: #fff; }
.auth-content h2 { font-size: 28px; margin-bottom: 8px; color: #fff; }
.auth-content p { color: var(--text-dim); font-size: 14px; margin-bottom: 24px; }

/* Payment Methods */
.payment-methods { display: flex; flex-direction: column; gap: 12px; }
.payment-radio {
  padding: 16px;
  background: var(--bg-elevated);
  border: 1px solid var(--border-color);
  border-radius: 16px;
  display: flex; align-items: center; gap: 16px;
  cursor: pointer; transition: var(--transition);
}
.payment-radio:hover { border-color: rgba(255,255,255,0.2); }
.payment-radio.selected { border-color: var(--gold); background: rgba(212, 175, 55, 0.05); }
.pay-icon { font-size: 24px; }
.pay-info { flex: 1; }
.pay-info strong { display: block; font-size: 14px; color: #fff; }
.pay-info span { font-size: 11px; color: var(--text-dim); }
.pay-check { opacity: 0; color: var(--gold); font-size: 18px; }
.payment-radio.selected .pay-check { opacity: 1; }

.summary-row {
  display: flex; justify-content: space-between;
  margin-bottom: 12px; font-size: 14px;
}
.summary-row .label { color: var(--text-dim); }
.summary-row .value { color: #fff; font-weight: 600; }
.summary-row.total {
  margin-top: 20px; padding-top: 20px; border-top: 1px dashed var(--border-color);
  font-size: 20px;
}
.summary-row.total .label { color: #fff; font-weight: 800; }
.summary-row.total .value { color: var(--gold); font-weight: 800; }

.secure-notice { 
  text-align: center; font-size: 11px; color: var(--text-dim); 
  margin-top: 16px; text-transform: uppercase; letter-spacing: 1px;
}

/* Utils */
.badge {
  display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 10px; font-weight: 800; text-transform: uppercase;
}

/* Sidebar Toggle functionality */
.hamburger-btn {
  background: transparent; border: none; cursor: pointer;
  display: flex; flex-direction: column; gap: 5px;
  padding: 10px;
}
.hb-line { width: 24px; height: 2px; background: #fff; transition: var(--transition); }

.sidebar-visible { transform: translateX(0) !important; }
.overlay-visible { opacity: 1 !important; visibility: visible !important; }

@media (max-width: 1024px) {
  .admin-sidebar {
    position: fixed; top: 0; left: 0; bottom: 0;
    transform: translateX(-100%);
    z-index: 1001; transition: var(--transition);
  }
  .sidebar-overlay {
    position: fixed; top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0,0,0,0.7); backdrop-filter: blur(4px);
    z-index: 1000; opacity: 0; visibility: hidden; transition: var(--transition);
  }
}
