generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum PlanType {
  trial
  basic
  premium
}

enum PlanStatus {
  active
  inactive
}

enum AppointmentStatus {
  pending
  confirmed
  completed
  noshow
}

enum PaymentMethod {
  in_barbershop
  pix
  credit_card
}

model Shop {
  id              String    @id @default(uuid())
  slug            String?   @unique
  name            String
  address         String?
  email           String    @unique
  password        String
  mpAccessToken   String?
  plan            PlanType   @default(trial)
  planStatus      PlanStatus @default(active)
  trialEndsAt     DateTime?
  planPaidUntil   DateTime?
  zapiInstance    String?
  zapiToken       String?
  pixKey          String?   // Chave Pix da Barbearia para recebimentos
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  services        Service[]
  barbers         Barber[]
  discounts       Discount[]
  appointments    Appointment[]
  hours           Hours[]
  expenses        Expense[]
  clients         Client[]
  blocks          BlockTime[]
  subscriptionPlans SubscriptionPlan[]
}

model Service {
  id          String   @id @default(uuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name        String
  price       Decimal
  duration    Int
  desc        String
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Barber {
  id          String   @id @default(uuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name        String
  role        String
  emoji       String
  commissionPct Float  @default(0) // Porcentagem de comissão (ex: 50.0)
  pixKey      String?  // Chave Pix do Barbeiro
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Discount {
  id          String   @id @default(uuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  code        String
  type        String   // "percent" or "fixed"
  value       Float
  active      Boolean  @default(true)
  desc        String
  uses        Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Appointment {
  id             String   @id @default(uuid())
  shopId         String
  shop           Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  clientName     String
  clientPhone    String
  serviceNames   String
  barberName     String
  date           String
  time           String
  status         String   // pending, confirmed, completed, no-show
  paymentStatus  String   // pendente, pago, cancelado
  paymentMethod  String   // "Na barbearia", "Pix Antecipado", "Cartão de Crédito"
  price          Decimal
  commissionValue Decimal @default(0) // Valor da comissão do barbeiro calculado no momento do corte

  // To track external payments
  externalPaymentId String?

  archived       Boolean  @default(false)
  reminded       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Hours {
  id        String   @id @default(uuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  day       String   // "Segunda", "Terça", "Quarta", "Quinta", "Sexta", "Sábado", "Domingo"
  open      Boolean  @default(true)
  start     String   @default("08:00") // "HH:MM"
  end       String   @default("20:00") // "HH:MM"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shopId, day])
}

model Expense {
  id          String   @id @default(uuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  description String
  value       Decimal
  date        DateTime // Store full date
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Client {
  id            String   @id @default(uuid())
  shopId        String
  shop          Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name          String
  phone         String
  password      String?  // Opcional para clientes antigos que não criaram conta ainda
  notes         String?
  totalVisits   Int      @default(0)
  totalSpent    Float    @default(0)

  // Clube do Barbeiro
  planId        String?
  plan          SubscriptionPlan? @relation(fields: [planId], references: [id])
  planExpiresAt DateTime?
  cutsUsed      Int      @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([shopId, phone])
}

model SubscriptionPlan {
  id          String   @id @default(uuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name        String
  price       Decimal
  maxCuts     Int      @default(4)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clients     Client[]
}

model BlockTime {
  id          String   @id @default(uuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  barberName  String   // Qual barbeiro está bloqueado ("Todos" ou nome específico)
  date        DateTime // Store full date
  startTime   String   // HH:MM (keep as string for now)
  endTime     String   // HH:MM
  reason      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
